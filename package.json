{
  "name": "pptx2web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare:katex-css": "node scripts/generate-katex-css.mjs",
    "predev": "npm run prepare:katex-css",
    "dev": "vite",
